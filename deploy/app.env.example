# Proyecto Dokploy: app (SvelteKit)
# POSTGRES_PASSWORD = la misma que en el proyecto db.
# POSTGRES_HOST: hostname único en dokploy-network (no `postgres` — colisiona con presupuestossys).

POSTGRES_HOST=auditapp-postgres
POSTGRES_PASSWORD=la-misma-clave-que-db
SESSION_SECRET=genera-con-openssl-rand-base64-32
PUBLIC_APP_URL=https://app.auditoriaserviciosysistemas.com.ar

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=auditapp
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# Custom domain público del bucket (previews/descargas). Sin esto, presign GET va a la API S3 y puede dar 403.
# R2_PUBLIC_BASE_URL=https://auditapp.auditoriaserviciosysistemas.com.ar

# Informe IA (#14) — sin esto «Generar informe» responde 503
ANTHROPIC_API_KEY=
# INFORME_CLAUDE_MODEL=claude-opus-4-8
# INFORME_GENERATION_TIMEOUT_MS=300000

# AUTO_SEED=false

# Logs JSON en Dokploy (default info). Para diagnosticar: LOG_LEVEL=debug
# LOG_LEVEL=info
