{
  "name": "auditapp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite dev",
    "dev:local": "./dev.sh",
    "build": "vite build",
    "build:migrate": "node scripts/build-migrate.mjs",
    "prepush": "./scripts/pre-push.sh",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:seed:templates": "tsx scripts/db-seed-templates.ts",
    "db:reset": "tsx scripts/db-reset.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.20.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.3",
    "svelte": "^5.25.6",
    "svelte-check": "^4.1.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.5",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@node-rs/argon2": "^2.0.2",
    "aws4fetch": "^1.0.20",
    "csv-parse": "^6.2.1",
    "heic2any": "^0.0.4",
    "postgres": "^3.4.5",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  }
}
