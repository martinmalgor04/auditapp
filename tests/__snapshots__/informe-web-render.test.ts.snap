      <div class="score-info"><div class="name">Gestión de datos</div><div class="detail">Parcial · No · Manual</div></div>
      <div class="score-right"><div class="bar"><i data-w="55"></i></div><div class="score-val" data-canonical="score">55</div></div>
    </div>
  </div>
