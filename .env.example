# Postgres (local dev — docker-compose expone localhost:5432)
DATABASE_URL=postgres://auditapp:changeme@localhost:5432/auditapp

# Postgres (producción Dokploy — hostname único en dokploy-network)
# DATABASE_URL=postgres://auditapp:changeme@auditapp-postgres:5432/auditapp

# Usuarios dev (seed db:seed) — solo entorno local
# admin@serviciosysistemas.com.ar / changeme-admin
# facu@serviciosysistemas.com.ar / changeme-tech
# simon@serviciosysistemas.com.ar / changeme-tech

# Auth — generar con: openssl rand -base64 32
SESSION_SECRET=replace-with-random-secret-min-32-chars

# Cloudflare R2 (feature storage_r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=auditapp
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Custom domain público del bucket (previews). Ver deploy/app.env.example.
# R2_PUBLIC_BASE_URL=https://auditapp.auditoriaserviciosysistemas.com.ar
# TTL presigned URLs (segundos, default 900)
R2_PRESIGN_TTL_SECONDS=900

# Identificador estable de la instancia (export/import de auditorías #20).
# Forma parte de la clave de dedupe del bundle. Fallback: 'unknown'.
# INSTANCE_ID=dev-local

# URL pública de la app
PUBLIC_APP_URL=http://localhost:5173
# Producción Dokploy + Traefik:
# PUBLIC_APP_URL=https://app.auditoriaserviciosysistemas.com.ar

# Puerto adapter-node (contenedor / preview)
PORT=3000

# Límite de body de adapter-node (default 512K). Subido para payloads del form
# técnico (tablas grandes, import de backup). Setear también en Dokploy.
BODY_SIZE_LIMIT=2M

# Logs estructurados JSON en stdout (debug | info | warn | error). Default: info en prod.
# LOG_LEVEL=info

# Seed automático en Docker (default: activo). Solo corre si app_user está vacío.
# AUTO_SEED=false

# ── Informe IA (#14) ──
# API key de Anthropic; sin ella el POST de generación responde 503.
ANTHROPIC_API_KEY=
# Modelo Claude del pipeline (default: claude-opus-4-8)
# INFORME_CLAUDE_MODEL=claude-opus-4-8
# Timeout del guard de generación colgada, en ms (default: 300000)
# INFORME_GENERATION_TIMEOUT_MS=300000

# ── Contexto IA fase 2 (#17) — todo off por defecto ──
# Activar cada fuente con valor exacto "1"
# INFORME_RAG_ENABLED=0
# INFORME_CATALOGO_ENABLED=0
# INFORME_FEWSHOT_ENABLED=0
# Supabase RAG Tango (solo lectura, RPC match_documents)
# RAG_TANGO_SUPABASE_URL=
# RAG_TANGO_SUPABASE_KEY=
# Embeddings de consulta (Gemini)
# GEMINI_API_KEY=
# RAG_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# RAG_MATCH_THRESHOLD=0.40
# RAG_MATCH_COUNT=8
# INFORME_RAG_TIMEOUT_MS=10000
# INFORME_RAG_MAX_TOKENS=6000
# INFORME_FEWSHOT_MAX_EXAMPLES=2
# INFORME_FEWSHOT_MAX_TOKENS=4000
# INFORME_PROMPT_MAX_TOKENS=150000

# ── Presupuesto presupuestossys (#16) ──
# URL base del servicio presupuestossys (sin slash final).
PSYS_API_URL=
# API key M2M dedicada; sin ella el POST responde 503.
PSYS_API_KEY=

# ── CRM leads (#13) ──
# Token Bearer para POST /api/crm/leads/batch (n8n/Firecrawl).
CRM_API_TOKEN=
