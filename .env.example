# Postgres (local dev — docker-compose expone localhost:5432)
DATABASE_URL=postgres://auditapp:changeme@localhost:5432/auditapp

# Postgres (producción Dokploy — hostname único en dokploy-network)
# DATABASE_URL=postgres://auditapp:changeme@auditapp-postgres:5432/auditapp

# Usuarios dev (seed db:seed) — solo entorno local
# admin@serviciosysistemas.com.ar / changeme-admin
# facu@serviciosysistemas.com.ar / changeme-tech
# simon@serviciosysistemas.com.ar / changeme-tech

# Auth — generar con: openssl rand -base64 32
SESSION_SECRET=replace-with-random-secret-min-32-chars

# Cloudflare R2 (feature storage_r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=auditapp
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Custom domain público del bucket (previews). Ver deploy/app.env.example.
# R2_PUBLIC_BASE_URL=https://auditapp.auditoriaserviciosysistemas.com.ar
# TTL presigned URLs (segundos, default 900)
R2_PRESIGN_TTL_SECONDS=900

# Identificador estable de la instancia (export/import de auditorías #20).
# Forma parte de la clave de dedupe del bundle. Fallback: 'unknown'.
# INSTANCE_ID=dev-local

# URL pública de la app
PUBLIC_APP_URL=http://localhost:5173
# Producción Dokploy + Traefik:
# PUBLIC_APP_URL=https://app.auditoriaserviciosysistemas.com.ar

# Detrás de proxy (Traefik/Dokploy): para que getClientAddress() —y por ende el
# rate-limit de login— use la IP real del cliente y no la del proxy, configurar
# estas vars de @sveltejs/adapter-node. Sin esto el rate-limit puede agrupar a
# todos bajo una IP (over-block) o ser evadible spoofeando X-Forwarded-For.
# ADDRESS_HEADER=X-Forwarded-For
# XFF_DEPTH=1

# Puerto adapter-node (contenedor / preview)
PORT=3000

# Límite de body de adapter-node (default 512K). Subido para payloads del form
# técnico (tablas grandes, import de backup) y para subida de audio de reunión
# (#12), que va por POST directo al servidor. Debe ser >= REUNION_MAX_AUDIO_BYTES.
# Setear también en Dokploy.
BODY_SIZE_LIMIT=120M

# Logs estructurados JSON en stdout (debug | info | warn | error). Default: info en prod.
# LOG_LEVEL=info

# Seed automático en Docker (default: activo). Solo corre si app_user está vacío.
# AUTO_SEED=false

# ── Informe IA (#14) ──
# API key de Anthropic; sin ella el POST de generación responde 503.
ANTHROPIC_API_KEY=
# Modelo Claude del pipeline (default: claude-opus-4-8)
# INFORME_CLAUDE_MODEL=claude-opus-4-8
# Timeout del guard de generación colgada, en ms (default: 300000)
# INFORME_GENERATION_TIMEOUT_MS=300000

# ── Contexto IA fase 2 (#17) — todo off por defecto ──
# Activar cada fuente con valor exacto "1"
# INFORME_RAG_ENABLED=0
# INFORME_CATALOGO_ENABLED=0
# INFORME_FEWSHOT_ENABLED=0
# Supabase RAG Tango (solo lectura, RPC match_documents)
# RAG_TANGO_SUPABASE_URL=
# RAG_TANGO_SUPABASE_KEY=
# Embeddings de consulta (Gemini)
# GEMINI_API_KEY=
# RAG_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# RAG_MATCH_THRESHOLD=0.40
# RAG_MATCH_COUNT=8
# INFORME_RAG_TIMEOUT_MS=10000
# INFORME_RAG_MAX_TOKENS=6000
# INFORME_FEWSHOT_MAX_EXAMPLES=2
# INFORME_FEWSHOT_MAX_TOKENS=4000
# INFORME_PROMPT_MAX_TOKENS=150000

# ── Presupuesto presupuestossys (#16) ──
# URL base del servicio presupuestossys (sin slash final).
PSYS_API_URL=
# API key M2M dedicada; sin ella el POST responde 503.
PSYS_API_KEY=

# ── CRM leads (#13) ──
# Token Bearer para POST /api/crm/leads/batch (n8n/Firecrawl).
CRM_API_TOKEN=

# ── Asistente de reunión (#12) ──
# Modo del pipeline: "direct" (in-process) o "webhook" (n8n/externo).
REUNION_PIPELINE_MODE=direct
# Límite de tamaño del audio en bytes (default 100 MB).
REUNION_MAX_AUDIO_BYTES=104857600
# Días de retención del audio en R2 antes de archivar (default 365).
REUNION_AUDIO_RETENTION_DAYS=365
# Proveedor STT: "openai" (Whisper) o "mock" (solo tests). El STT sigue en OpenAI Whisper (#24).
REUNION_STT_PROVIDER=openai
# API key de OpenAI (requerida en modo direct para el STT/Whisper).
# OPENAI_API_KEY=

# ── Email (SMTP, #49) ──
# SMTP genérico (nodemailer). Opcional en dev: sin SMTP_HOST → dry-run (no envía real).
SMTP_HOST=<smtp.example.com>
SMTP_PORT=<587>
SMTP_USER=<usuario@serviciosysistemas.com.ar>
SMTP_PASS=<contraseña-smtp>
SMTP_FROM=<auditorias@serviciosysistemas.com.ar>
# true para TLS implícito (puerto 465); false/omitido para STARTTLS (587).
SMTP_SECURE=<false>

# ── Push PWA (Web Push / VAPID, #53) ──
# Generar con: npx web-push generate-vapid-keys
# Las tres vars son opcionales. Sin ellas el push opera en modo no-op (no envía, no rompe el arranque).
VAPID_PUBLIC_KEY=<clave-publica-base64url>
VAPID_PRIVATE_KEY=<clave-privada-base64url>
# mailto: o https: de la entidad responsable del push
VAPID_SUBJECT=<mailto:auditorias@serviciosysistemas.com.ar>

# ── Análisis de reunión con Claude (#24) ──
# El ANÁLISIS (extracción de propuestas) usa la Messages API de Anthropic, no OpenAI.
# Requiere ANTHROPIC_API_KEY (declarada arriba en la sección Informe IA #14) en modo direct.
# Modelo de análisis/extracción (default: claude-sonnet-4-6).
# REUNION_ANALYSIS_MODEL=claude-sonnet-4-6
# Umbral mínimo de confidence para conservar una propuesta, en [0,1] (default: 0.5).
# REUNION_CONFIDENCE_MIN=0.5
# Activa el verificador Tier 2 (juez por propuesta). "true" para activar (default: false).
# REUNION_VERIFIER_ENABLED=false
# Modelo del verificador/juez (default: claude-haiku-4-5).
# REUNION_VERIFIER_MODEL=claude-haiku-4-5
# URL del webhook n8n (solo modo webhook).
# N8N_REUNION_WEBHOOK_URL=
# Secret HMAC para verificar callbacks de webhook.
# REUNION_CALLBACK_SECRET=
# URL base del app para construir la URL de callback (solo modo webhook).
# REUNION_CALLBACK_BASE_URL=
